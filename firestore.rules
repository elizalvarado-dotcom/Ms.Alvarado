rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── drafts/{assignmentId}_{studentId} ─────────────────────────────────
    match /drafts/{docId} {
      allow read: if request.auth != null
                  && resource.data.userEmail == request.auth.token.email;

      allow write: if request.auth != null
                   && request.resource.data.userEmail == request.auth.token.email;
    }

    // ── submissions/{assignmentId}_{studentId} ─────────────────────────────
    match /submissions/{docId} {
      allow get: if request.auth != null
                 && resource.data.userEmail == request.auth.token.email;

      allow create: if request.auth != null
                    && request.resource.data.userEmail == request.auth.token.email;

      allow update, delete: if false;
    }

    // ── scores/{activity}_{email} ──────────────────────────────────────────
    // Students write their own scores; any signed-in user (teacher) can read all.
    match /scores/{docId} {
      // Any authenticated user can read scores (teacher dashboard)
      allow read: if request.auth != null;

      // Students can only create/update their own score row
      allow write: if request.auth != null
                   && request.resource.data.email == request.auth.token.email;
    }

    // ── homework/{docId} ──────────────────────────────────────────────────
    // Students write homework submissions; any signed-in user can read.
    match /homework/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── feedback/{docId} ──────────────────────────────────────────────────
    // Students submit feedback; any signed-in user can read.
    match /feedback/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── students/{uid} ────────────────────────────────────────────────────
    // Students read/write their own period record; any signed-in user can read.
    match /students/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
